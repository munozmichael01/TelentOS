// Espejo tipado del modelo de datos. Decisión: la fuente de verdad de las
// migraciones es /supabase/migrations (SQL), porque RLS, policies y buckets de
// Storage no son expresables en Prisma. Este schema sirve como documentación
// tipada del modelo y permite `prisma migrate diff` contra DATABASE_URL si se
// quiere evolucionar vía Prisma. Las queries en runtime usan supabase-js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String     @unique
  logoUrl     String?    @map("logo_url")
  description String?
  website     String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  jobs        Job[]
  employees   Employee[]

  @@map("companies")
}

model Job {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String        @map("company_id") @db.Uuid
  title              String
  description        String?
  skills             String[]      @default([])
  salaryMin          Int?          @map("salary_min")
  salaryMax          Int?          @map("salary_max")
  salaryCurrency     String        @default("EUR") @map("salary_currency")
  location           String?
  employmentType     String        @default("full_time") @map("employment_type")
  sector             String?
  department         String?
  category           String?
  experienceMinYears Int           @default(0) @map("experience_min_years")
  status             String        @default("draft")
  source             String        @default("manual")
  externalId         String?       @map("external_id")
  dedupeHash         String?       @map("dedupe_hash")
  createdBy          String?       @map("created_by") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @default(now()) @map("updated_at") @db.Timestamptz
  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stages             JobStage[]
  campaigns          Campaign[]
  applications       Application[]

  @@map("jobs")
}

model JobStage {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId        String        @map("job_id") @db.Uuid
  name         String
  orderIndex   Int           @default(0) @map("order_index")
  isTerminal   Boolean       @default(false) @map("is_terminal")
  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("job_stages")
}

model Channel {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String     @unique
  kind      String     @default("job_board")
  baseCpa   Decimal    @default(20) @map("base_cpa")
  audience  String?
  campaigns Campaign[]

  @@map("channels")
}

model Campaign {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId        String   @map("job_id") @db.Uuid
  channelId    String   @map("channel_id") @db.Uuid
  status       String   @default("active")
  objective    String   @default("volume")
  budget       Decimal  @default(0)
  priority     Int      @default(1)
  copy         String?
  views        Int      @default(0)
  applications Int      @default(0)
  spend        Decimal  @default(0)
  startedAt    DateTime @default(now()) @map("started_at") @db.Timestamptz
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  channel      Channel  @relation(fields: [channelId], references: [id])

  @@map("campaigns")
}

model Candidate {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  email           String
  phone           String?
  location        String?
  skills          String[]      @default([])
  experienceYears Int           @default(0) @map("experience_years")
  cvUrl           String?       @map("cv_url")
  summary         String?
  source          String        @default("manual")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  applications    Application[]

  @@map("candidates")
}

model Application {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId       String             @map("job_id") @db.Uuid
  candidateId String             @map("candidate_id") @db.Uuid
  stageId     String?            @map("stage_id") @db.Uuid
  fitScore    Int?               @map("fit_score")
  source      String             @default("career_site")
  utm         Json               @default("{}")
  status      String             @default("open")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  job         Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  stage       JobStage?          @relation(fields: [stageId], references: [id])
  events      ApplicationEvent[]
  notes       Note[]
  interviews  Interview[]

  @@unique([jobId, candidateId])
  @@map("applications")
}

model ApplicationEvent {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  type          String
  fromStage     String?     @map("from_stage")
  toStage       String?     @map("to_stage")
  reason        String?
  actorId       String?     @map("actor_id") @db.Uuid
  actorEmail    String?     @map("actor_email")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_events")
}

model Note {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  authorId      String?     @map("author_id") @db.Uuid
  authorEmail   String?     @map("author_email")
  body          String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Interview {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String              @map("application_id") @db.Uuid
  stageId       String?             @map("stage_id") @db.Uuid
  scheduledAt   DateTime            @map("scheduled_at") @db.Timestamptz
  durationMin   Int                 @default(45) @map("duration_min")
  interviewer   String?
  meetingUrl    String?             @map("meeting_url")
  status        String              @default("scheduled")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  application   Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  feedback      InterviewFeedback[]

  @@map("interviews")
}

model EvaluationTemplate {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  stageName String?             @map("stage_name")
  questions Json                @default("[]")
  feedback  InterviewFeedback[]

  @@map("evaluation_templates")
}

model InterviewFeedback {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String              @map("interview_id") @db.Uuid
  templateId  String?             @map("template_id") @db.Uuid
  ratings     Json                @default("{}")
  overall     Int?
  comments    String?
  authorEmail String?             @map("author_email")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz
  interview   Interview           @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  template    EvaluationTemplate? @relation(fields: [templateId], references: [id])

  @@map("interview_feedback")
}

model Employee {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String             @map("company_id") @db.Uuid
  candidateId       String?            @map("candidate_id") @db.Uuid
  applicationId     String?            @map("application_id") @db.Uuid
  name              String
  email             String?
  roleTitle         String?            @map("role_title")
  department        String?
  startDate         DateTime?          @map("start_date") @db.Date
  contractType      String             @default("indefinido") @map("contract_type")
  managerId         String?            @map("manager_id") @db.Uuid
  vacationDaysTotal Int                @default(23) @map("vacation_days_total")
  status            String             @default("active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager           Employee?          @relation("OrgChart", fields: [managerId], references: [id])
  reports           Employee[]         @relation("OrgChart")
  documents         EmployeeDocument[]
  onboardingTasks   OnboardingTask[]
  timesheets        Timesheet[]
  timeOffRequests   TimeOffRequest[]

  @@map("employees")
}

model EmployeeDocument {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  name       String
  fileUrl    String   @map("file_url")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_documents")
}

model OnboardingTask {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  title       String
  description String?
  assignee    String?
  dueDate     DateTime? @map("due_date") @db.Date
  status      String    @default("pending")
  orderIndex  Int       @default(0) @map("order_index")
  generatedBy String    @default("manual") @map("generated_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("onboarding_tasks")
}

model Timesheet {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  workDate   DateTime @map("work_date") @db.Date
  hours      Decimal
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("timesheets")
}

model TimeOffRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  days       Decimal
  type       String   @default("vacation")
  status     String   @default("pending")
  approver   String?
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("time_off_requests")
}

model AgentRun {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent     String
  input     Json     @default("{}")
  output    Json     @default("{}")
  status    String   @default("ok")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("agent_runs")
}
