# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL y claves: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave service_role (solo servidor). Se usa para el flujo público del career
# site (crear candidaturas sin sesión) y para subir CVs. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ── OpenAI ──────────────────────────────────────────────────────────────────
# Clave para los agentes (GPT-4o con tool calling). Si se omite, los agentes
# funcionan en modo heurístico determinista (útil para demo sin coste).
OPENAI_API_KEY=sk-...

# ── App ─────────────────────────────────────────────────────────────────────
# URL pública (para enlaces del career site). En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
